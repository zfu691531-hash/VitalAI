# ===================================
# VitalAI Application
# ===================================
APP_NAME=VitalAI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
VITALAI_RUNTIME_ROLE=default
LOG_LEVEL=INFO
VITALAI_REPORTING_ENABLED=
VITALAI_RUNTIME_CONTROL_ENABLED=
VITALAI_ADMIN_TOKEN=
VITALAI_RUNTIME_SIGNALS_ENABLED=
VITALAI_RUNTIME_SNAPSHOT_STORE_PATH=
VITALAI_PROFILE_MEMORY_DB_PATH=
VITALAI_INTENT_RECOGNIZER=rule_based
VITALAI_BERT_INTENT_MODEL_PATH=
VITALAI_BERT_INTENT_CONFIDENCE_THRESHOLD=0.65
VITALAI_BERT_INTENT_LABELS=health_alert,daily_life_checkin,mental_care_checkin,profile_memory_update,profile_memory_query,unknown
VITALAI_INTENT_DECOMPOSER=placeholder

# ===================================
# Base / Database
# ===================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=vitalai
DB_CHARSET=utf8mb4
BASE_DB_NAME=ric_ai_base

# ===================================
# Redis
# ===================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===================================
# LLM Basic
# ===================================
LLM_TIMEOUT=30

# ===================================
# Qwen / DashScope
# ===================================
DSC_API_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_DEFAULT_MODEL=qwen3-max
DASHSCOPE_API_KEY=your_dashscope_api_key
QWEN_EMBEDDING_MODEL_NAME=text-embedding-v3
QWEN_ASR_MODEL_NAME=qwen3-asr-flash
QWEN_OCR_MODEL_NAME=qwen-vl-ocr-latest

# ===================================
# DeepSeek
# ===================================
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===================================
# Email
# ===================================
SENDER_EMAIL=your_email@example.com
EMAIL_PASSWORD=your_email_password

# ===================================
# MinIO
# ===================================
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_ASR_TEXT_BUCKET_NAME=audio-text

# ===================================
# Milvus
# ===================================
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_URI=http://127.0.0.1:19530
MILVUS_USER=root
MILVUS_PASSWORD=change_me
MILVUS_DATABASE=default
MILVUS_TIMEOUT=10
MILVUS_COLLECTION_NAME=demo_collection
VECTOR_DIM=768
MILVUS_SECURE=False
MILVUS_ALIAS=default

# ===================================
# ffmpeg
# ===================================
FFMPEG_PATH=ffmpeg
