# 数据库连接（MySQL 8.0）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=aistu

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE_MINUTES=1440

# AI 大模型 API 配置
AI_API_BASE_URL=https://api.example.com/v1
AI_API_KEY=your_ai_api_key
AI_MODEL_NAME=your_model_name
AI_MODEL_NAME_LIGHT=your_light_model_name
AI_MODEL_NAME_STRONG=your_strong_model_name
AI_TIMEOUT=60
AI_EMBEDDING_MODEL_NAME=text-embedding-model-name
AI_EMBEDDING_DIM=1024

# Milvus 配置（新版校规问答试运行使用）
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=school_rule_chunks

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
