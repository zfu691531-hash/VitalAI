flowchart TD

    %% ════════════════════════════════════════════════════════════════
    %% 色彩方案（16种语义色）
    %% ════════════════════════════════════════════════════════════════
    classDef layerComm     fill:#1A4A7A,stroke:#0D2540,color:#fff,font-weight:bold
    classDef layerFeedback fill:#1A6B3A,stroke:#0D3D20,color:#fff,font-weight:bold
    classDef layerConflict fill:#5A2D82,stroke:#321659,color:#fff,font-weight:bold
    classDef layerInt      fill:#8B1A0E,stroke:#5C0F08,color:#fff,font-weight:bold
    classDef agentNode     fill:#0E6B4A,stroke:#074030,color:#fff,font-weight:bold
    classDef coreNode      fill:#1A3C5E,stroke:#0D1F30,color:#fff,font-weight:bold
    classDef aggNode       fill:#2258A0,stroke:#143568,color:#fff,font-weight:bold
    classDef shadowNode    fill:#6B3FA0,stroke:#3D1F66,color:#fff,font-weight:bold
    classDef monitorNode   fill:#0E7070,stroke:#073D3D,color:#fff,font-weight:bold
