    %% ════════════════════════════════════════════════════════════════
    %% 主干连接线（骨架流程）
    %% ════════════════════════════════════════════════════════════════

    %% 输入层 → 通信层 → 聚合器
    A_HEALTH & A_DAILY & A_MENTAL & A_INTEL & A_TOOL & A_PRIVACY & A_INTREPORT -->|"原始事件上报\n(统一消息信封·trace_id)"| AGG_IN
    MSG_ENV -.->|"所有消息遵循信封格式"| AGG_IN
    TRACE -.->|"trace_id贯穿全链路"| DC_IN

    %% 聚合器 → Decision Core
    AGG_OUT -->|"结构化摘要"| DC_IN

    %% Decision Core → 四层机制触发
    DC_TREE -->|"检测到紧急信号"| S2
    DC_TREE -->|"多Agent竞争资源"| CONF_INTENT
    DC_OUT -->|"反馈事件触发"| L1_TRIG
    DC_OUT -->|"执行指令下发"| EX_DAILY & EX_HEALTH & EX_MENTAL & EX_TOOL & EX_NOTIFY & EX_PRIVACY

    %% Decision Core → 数据库
    DC_CTX -->|"查询用户状态+热数据"| DB_ROUTER

    %% 反馈层 → 数据库写入
    L2_WRITE -->|"更新用户画像"| WARM
    L3_EVOLVE -->|"更新长期偏好+权重"| COLD

    %% 冲突仲裁 → Decision Core输出
    CG_AUTO & CG_USER & CR_SOLVE & CC_RULE -->|"仲裁结果"| DC_OUT

    %% 中断层 → 快照 → Shadow
    P0_SNAP & P1_SNAP & P2_SNAP -->|"全局快照"| SHADOW

    %% 中断执行 → 反馈
    P0_ACT & P1_ACT & P2_ACT & P3_ACT -->|"执行完成"| L1_TRIG

    %% 执行层 → 反馈
    EX_DAILY & EX_HEALTH & EX_MENTAL & EX_TOOL -->|"执行结果\n(FEEDBACK_POS/NEG)"| L1_TRIG

    %% 容灾体系
    HM_THRESHOLDS -->|"检测到失联"| SHADOW_TAKE
    DC_SYNC -->|"每次决策后同步"| SHADOW

    %% 反馈 → 智能汇报 → 聚合器
    L3_EVOLVE -->|"更新分析参数"| A_INTEL

    %% P0特殊通道
    P0_TRG -->|"P0高优先级直通"| P0_CHANNEL -.->|"绕过所有队列"| S2

    %% 通信层容错路径
    FAULT -->|"失败消息"| DLQ
    MODE_QUEUE -->|"Agent离线时"| FAULT

