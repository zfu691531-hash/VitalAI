    classDef p1Node        fill:#A05800,stroke:#5C3200,color:#fff,font-weight:bold
    classDef p2Node        fill:#806000,stroke:#4A3800,color:#fff,font-weight:bold
    classDef p3Node        fill:#2E6B20,stroke:#194010,color:#fff,font-weight:bold
    classDef normalNode    fill:#E8EAED,stroke:#9AA0A6,color:#1A3C5E
    classDef warnNode      fill:#6B1A1A,stroke:#3D0D0D,color:#fff,font-weight:bold
